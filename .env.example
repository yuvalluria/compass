# =============================================================================
# COMPASS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED in production)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:compass@localhost:5432/compass

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# CORS allowed origins (comma-separated)
# Development: http://localhost:8501
# Production: https://your-domain.com,https://app.your-domain.com
CORS_ORIGINS=http://localhost:8501

# -----------------------------------------------------------------------------
# LLM Configuration (Ollama)
# -----------------------------------------------------------------------------
# Ollama server URL
OLLAMA_HOST=http://localhost:11434

# Model to use for intent extraction
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# Backend API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Frontend API URL (used by Streamlit UI)
API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Deployment Configuration
# -----------------------------------------------------------------------------
# Use vLLM simulator instead of real GPUs (true for development)
SIMULATOR_MODE=true

# Default Kubernetes namespace for deployments
K8S_NAMESPACE=default

# -----------------------------------------------------------------------------
# Debug Configuration
# -----------------------------------------------------------------------------
# Enable debug logging (true/false)
COMPASS_DEBUG=false
