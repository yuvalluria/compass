# =============================================================================
# COMPASS - Unified .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Environment
.env
.env.local

# Logs
*.log
logs/
!logs/.gitkeep
!logs/prompts/.gitkeep

# Generated configs (YAML can be regenerated)
generated_configs/*.yaml
generated_configs/*.yml
!generated_configs/.gitkeep

# Ollama
.ollama/

# Streamlit
.streamlit/secrets.toml

# Runtime
.pids/

# Database
*.sql
!scripts/schema.sql

# Temporary files
*.tmp

# Output files (can be regenerated)
best_models_*.csv

# Large data files (keep configs)
!data/**/*.json
!configs/**/*.json

# Model weights (download separately)
*.bin
*.onnx
*.pt
*.pth
*.safetensors
